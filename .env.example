# .env y .env.example
PORT=4000
DB_URL=
JWT_SECRET=
# En producción usar lista separada por comas, ej:
# FRONTEND_URL=https://joyeriakob.com,https://www.joyeriakob.com
FRONTEND_URL=http://localhost:5173
UPLOADS_DIR=

# --- Login con Google (OAuth) ---
# Client ID del OAuth 2.0 creado en Google Cloud Console (tipo Web).
GOOGLE_CLIENT_ID=

# --- Envío de emails (Resend) ---
RESEND_API_KEY=
# Remitente verificado en Resend, ej: Joyería KOB <noreply@joyeriakob.com>
EMAIL_FROM=
