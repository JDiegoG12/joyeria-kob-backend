# .env y .env.example
PORT=4000
DB_URL=
JWT_SECRET=
# En producción usar lista separada por comas, ej:
# FRONTEND_URL=https://joyeriakob.com,https://www.joyeriakob.com
FRONTEND_URL=http://localhost:5173
UPLOADS_DIR=

# --- Dynamic rendering para bots (SEO) ---
# URL pública del FRONTEND (dominio canónico con www). Se usa para construir las
# URLs absolutas (canonical, og:url, enlaces) dentro del HTML de /render, ya que
# son las URLs que el usuario real visita y que Google debe indexar.
FRONTEND_PUBLIC_URL=https://www.joyeriakob.com
# URL pública de ESTE backend. Se usa solo para las URLs absolutas de imágenes
# (og:image y <img>), ya que los archivos viven físicamente aquí en /uploads.
API_PUBLIC_URL=https://api.joyeriakob.com
# Directorio público del FRONTEND (filesystem compartido). El pre-render escribe
# ahí los .html estáticos y el sitemap.xml. Ver SEO-DEPLOY.md.
FRONTEND_PUBLIC_DIR=/home/u708472935/domains/joyeriakob.com/public_html

# --- Timer interno del pre-render (sustituye al cron, deshabilitado en el plan) ---
# La app regenera el pre-render al arrancar y cada N horas. Todas son opcionales.
# Frecuencia en horas (default 6).
PRERENDER_INTERVAL_HOURS=6
# Poner en "false" para NO regenerar al arrancar la app.
PRERENDER_ON_BOOT=true
# Poner en "false" para desactivar el timer periódico (sin redeploy).
PRERENDER_TIMER_ENABLED=true

# --- Login con Google (OAuth) ---
# Client ID del OAuth 2.0 creado en Google Cloud Console (tipo Web).
GOOGLE_CLIENT_ID=

# --- Envío de emails (Resend) ---
RESEND_API_KEY=
# Remitente verificado en Resend, ej: Joyería KOB <noreply@joyeriakob.com>
EMAIL_FROM=
