// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DB_URL")
}

// ------------------------------
// Modelo: Category (Categorías con autorelación)
// ------------------------------
// Permite crear jerarquías de categorías (categorías padre → subcategorías)
// - Una categoría puede tener muchas subcategorías (relación uno a muchos consigo misma)
// - parentId es opcional (NULL para categorías raíz)
// - onDelete: Restrict impide eliminar una categoría que tenga subcategorías asociadas
// - Se mantiene la integridad referencial sin borrados en cascada no deseados
// ------------------------------
model Category {
  id          Int      @id @default(autoincrement())
  name        String   @db.VarChar(50)       // Nombre de la categoría (ej: "Cadena")
  slug        String   @unique @db.VarChar(50) // Identificador único para URL (ej: "cadena-trenzada")
  description String?  @db.Text               // Descripción opcional
  parentId    Int?                            // ID de la categoría padre (NULL si es raíz)
  createdAt   DateTime @default(now()) @map("created_at")

  // Relación autorreferenciada
  parent   Category?  @relation("CategoryToSubcategory", fields: [parentId], references: [id], onDelete: Restrict)
  children Category[] @relation("CategoryToSubcategory")

  // Índices para mejorar rendimiento en consultas jerárquicas
  @@index([parentId])
  @@map("categories")
}
