// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DB_URL")
}

// ------------------------------
// Enums
// ------------------------------
enum ProductStatus {
  AVAILABLE
  OUT_OF_STOCK
  HIDDEN
}

enum SocialNetwork {
  YOUTUBE
  TIKTOK
  INSTAGRAM
  FACEBOOK
  OTHER
}

// ------------------------------
// Modelo: Category (Categorías con autorelación)
// ------------------------------
// Permite crear jerarquías de categorías (categorías padre → subcategorías)
// - Una categoría puede tener muchas subcategorías (relación uno a muchos consigo misma)
// - parentId es opcional (NULL para categorías raíz)
// - onDelete: Restrict impide eliminar una categoría que tenga subcategorías asociadas
// - Se mantiene la integridad referencial sin borrados en cascada no deseados
// ------------------------------
model Category {
  id          Int      @id @default(autoincrement())
  name        String   @db.VarChar(50) 
  slug        String   @unique @db.VarChar(50) 
  description String?  @db.Text               
  parentId    Int?                            
  createdAt   DateTime @default(now()) @map("created_at")

  // Relaciones
  parent   Category?  @relation("CategoryToSubcategory", fields: [parentId], references: [id], onDelete: Restrict)
  children Category[] @relation("CategoryToSubcategory")
  products Product[]  // Relación: Una categoría puede tener muchos productos

  // Índices para mejorar rendimiento en consultas jerárquicas
  @@index([parentId])
  @@unique([parentId, name], name: "unique_parent_name") 
  @@map("categories")
}

// ------------------------------
// Modelo: Product (Catálogo de Joyas)
// ------------------------------
// Implementa el patrón Híbrido: Columnas tipadas para el negocio + JSON para la flexibilidad
// - id: Usa UUID para mayor seguridad en el frontend
// - categoryId: Apunta siempre a la categoría/subcategoría más específica
// - specifications: JSONB que varía según el tipo de joya (tallas, piedras, etc)
// ------------------------------
model Product {
  id              String        @id @default(uuid()) @db.Char(36)
  categoryId      Int           @map("category_id")
  name            String        @db.VarChar(100)
  description     String        @db.Text
  baseWeight      Decimal       @db.Decimal(10, 2) @map("base_weight")
  additionalValue Decimal       @db.Decimal(10, 2) @default(0) @map("additional_value")
  stock           Int           @default(1)
  status          ProductStatus @default(AVAILABLE)
  featured        FeaturedProduct? // Relación opcional con FeaturedProduct 

  // Columnas flexibles nativas de MySQL JSON
  specifications  Json          
  images          Json          
  
  createdAt       DateTime      @default(now()) @map("created_at")

  // Relación con Categoría
  // Restrict: Evita borrar una categoría si tiene productos asignados
  category        Category      @relation(fields: [categoryId], references: [id], onDelete: Restrict)

  @@index([categoryId])
  @@index([status]) // Índice útil para filtrar en el catálogo del cliente
  @@map("products")
}

// ------------------------------
// Modelo: FeaturedProduct (Productos Destacados)
// ------------------------------
// Almacena productos destacados para la página principal.
// --------------------------------
model FeaturedProduct {
  id        Int     @id @default(autoincrement())
  productId String  @unique @map("product_id") @db.Char(36) // Unique garantiza que no haya duplicados (Criterio 3)
  position  Int     // Guardará el orden (1 al 6) (Criterio 4)
  
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([position])
  @@map("featured_products")
}

// ------------------------------
// Modelo: SystemSetting (Configuraciones Globales)
// ------------------------------
// Almacena variables críticas del sistema (Ej: Precio del oro)
// ------------------------------
model SystemSetting {
  id               Int      @id @default(autoincrement())
  goldPricePerGram Decimal  @db.Decimal(10, 2) @map("gold_price_per_gram")
  lastUpdate       DateTime @updatedAt @map("last_update")
  
  @@map("system_settings")
}

// Modelo: GoldPriceHistory (Historial inmutable)
// ------------------------------
// Almacena cada cambio de precio para métricas y auditoría.
// ------------------------------
model GoldPriceHistory {
  id               Int      @id @default(autoincrement())
  goldPricePerGram Decimal  @db.Decimal(10, 2) @map("gold_price_per_gram")
  createdAt        DateTime @default(now()) @map("created_at")

  @@index([createdAt]) // Índice VITAL para ordenar métricas por fecha rápidamente
  @@map("gold_price_history")
}

enum UserRole {
  CLIENT
  ADMIN
}

model User {
  id        String   @id @default(uuid()) @db.Char(36)
  name      String @default("")
  lastName  String @default("")
  phone     String?  // Opcional
  email     String   @unique
  password  String
  role      UserRole @default(CLIENT)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@map("user")
}
model Banner {
  id        Int      @id @default(1)
  title     String
  subtitle  String?
  imageUrl  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@map("banner")
}

// ------------------------------
// Modelo: SocialContent (Contenido para Redes Sociales)
// ------------------------------
// Almacena tarjetas de contenido para mostrar en el frontend,
// enlazando a publicaciones de redes sociales.
// ------------------------------
model SocialContent {
  id            Int           @id @default(autoincrement())
  title         String        @db.VarChar(100)
  imageUrl      String        @map("image_url")
  link          String        @db.Text
  socialNetwork SocialNetwork @map("social_network")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  @@index([socialNetwork])
  @@map("social_contents")
}